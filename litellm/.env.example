# ============================================
# LiteLLM 企业级网关环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================

# --------------------------------------------
# 数据库配置
# --------------------------------------------
POSTGRES_USER=litellm
POSTGRES_PASSWORD=your_secure_db_password_here
POSTGRES_PORT=5432

# --------------------------------------------
# LiteLLM 核心配置
# --------------------------------------------
# Master Key: 管理员密钥，用于 Admin UI 登录和管理操作
# 必须以 sk- 开头，建议使用强随机字符串
LITELLM_MASTER_KEY=sk-change-me-to-strong-random-key

# Salt Key: 用于加密存储的上游 API Key
# 【重要】首次设置后不要更改，否则已加密数据将无法解密
LITELLM_SALT_KEY=sk-change-me-salt-key-32chars

# Admin UI 登录凭证
UI_USERNAME=admin
UI_PASSWORD=your_admin_ui_password

# LiteLLM 服务端口
LITELLM_PORT=4000

# 日志级别: DEBUG / INFO / WARNING / ERROR
LITELLM_LOG=INFO

# --------------------------------------------
# LLM 提供商 API Keys
# --------------------------------------------
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# 阿里云 Qwen (通义千问)
QWEN_API_KEY=sk-your-aliyun-dashscope-api-key

# Azure OpenAI (可选)
# AZURE_API_KEY=your-azure-api-key
# AZURE_API_BASE=https://your-resource.openai.azure.com
# AZURE_API_VERSION=2024-02-15-preview

# 本地 Ollama (可选)
# OLLAMA_API_BASE=http://host.docker.internal:11434
