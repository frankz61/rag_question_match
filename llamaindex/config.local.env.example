# 本地配置文件模板
# 复制为 config.local.env 并填写实际值
# 注意：config.local.env 不应提交到版本库

# Embedding 模型
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024
EMBED_BATCH_SIZE=4

# Milvus
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=llamaindex_bge_m3

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=test_rag

# Chunk 参数
CHUNK_SIZE=65535
CHUNK_OVERLAP=50

# OCR
OCR_LANG=ch
OCR_DEVICE=auto

# Hybrid RRF
HYBRID_RRF_K=60

# OpenAI 兼容网关（视觉对话）
OPENAI_API_BASE=http://localhost:4000/
OPENAI_API_KEY=
OPENAI_VISION_MODEL=qwen-vl-max
